# ---------------------------------------------------------------------------
# Hearsay configuration. Copy to `.env` and adjust. Every value has a default;
# the ones below mirror the docker-compose setup.
# ---------------------------------------------------------------------------

# --- Postgres (compose) ---
POSTGRES_USER=hearsay
POSTGRES_PASSWORD=hearsay
POSTGRES_DB=hearsay

# ===========================================================================
# API gateway (HEARSAY_ prefix)
# ===========================================================================
HEARSAY_LOG_LEVEL=INFO
HEARSAY_API_HOST=0.0.0.0
HEARSAY_API_PORT=8000

# Database (async driver). In compose this is injected from the POSTGRES_* vars.
HEARSAY_DATABASE_URL=postgresql+asyncpg://hearsay:hearsay@postgres:5432/hearsay

# GPU daemon location + per-request timeout (seconds).
HEARSAY_GPU_BASE_URL=http://gpu:8001
HEARSAY_GPU_REQUEST_TIMEOUT_S=600

# Engine placement: map each engine to "local" (GPU daemon) or "runpod".
# JSON object. RunPod targets are stubbed in v1 (see RunPod section).
HEARSAY_ENGINE_PLACEMENT={"kokoro":"local","chatterbox":"local","faster-whisper":"local","pyannote":"local"}

# STT model selection (config switch for large-v3-turbo / INT8 lives on the GPU).
HEARSAY_WHISPER_MODEL=large-v3
HEARSAY_WHISPER_COMPUTE_TYPE=float16
HEARSAY_KOKORO_DEFAULT_VOICE=af_heart
HEARSAY_CUDA_DEVICE=cuda

# Diarization (pyannote) — gated and OFF by default. Requires an HF token.
HEARSAY_DIARIZATION_ENABLED=false
HEARSAY_HF_TOKEN=

# RunPod burst target — present but unused in v1. The stubbed engine is
# selectable here; routing it via HEARSAY_ENGINE_PLACEMENT raises NotImplemented.
HEARSAY_RUNPOD_ENDPOINT=
HEARSAY_RUNPOD_API_KEY=
HEARSAY_RUNPOD_STUBBED_ENGINE=chatterbox

# Storage backend: "local" (disk) or "s3" (MinIO-compatible).
HEARSAY_STORAGE_BACKEND=local
HEARSAY_STORAGE_LOCAL_ROOT=/data/hearsay
HEARSAY_S3_ENDPOINT_URL=
HEARSAY_S3_BUCKET=hearsay
HEARSAY_S3_ACCESS_KEY=
HEARSAY_S3_SECRET_KEY=
HEARSAY_S3_REGION=us-east-1

# Bootstrap API key — auto-provisioned on startup so the service is usable.
# Generate your own: `openssl rand -hex 24` and prefix with sk-hearsay-.
HEARSAY_BOOTSTRAP_API_KEY=sk-hearsay-changeme

# Job queue worker.
HEARSAY_WORKER_ENABLED=true
HEARSAY_WORKER_POLL_INTERVAL_S=1.0

# Realtime / audio.
HEARSAY_REALTIME_SAMPLE_RATE=16000
HEARSAY_VAD_AGGRESSIVENESS=2

# ===========================================================================
# GPU daemon (HEARSAY_GPU_ prefix)
# ===========================================================================
HEARSAY_GPU_LOG_LEVEL=INFO
HEARSAY_GPU_HOST=0.0.0.0
HEARSAY_GPU_PORT=8001
HEARSAY_GPU_DEVICE=cuda
HEARSAY_GPU_COMPUTE_TYPE=float16

HEARSAY_GPU_WHISPER_MODEL=large-v3
HEARSAY_GPU_PRELOAD_WHISPER=true
HEARSAY_GPU_PRELOAD_KOKORO=true
HEARSAY_GPU_PRELOAD_CHATTERBOX=false
HEARSAY_GPU_KOKORO_DEFAULT_VOICE=af_heart

# Diarization on the GPU daemon (gated, OFF by default).
HEARSAY_GPU_DIARIZATION_ENABLED=false
HEARSAY_GPU_HF_TOKEN=

# VAD / realtime segmentation.
HEARSAY_GPU_SAMPLE_RATE=16000
HEARSAY_GPU_VAD_THRESHOLD=0.5
HEARSAY_GPU_VAD_MIN_SILENCE_MS=500
HEARSAY_GPU_VAD_WINDOW_MS=32
